{
  "name": "student-portal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "CampusConnect - Student Opportunity Sharing Portal",
  "author": "CampusConnect Team",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.5",
    "typescript-eslint": "^8.64.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,html}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.20.1",
    "npm": ">=10.0.0"
  }
}
